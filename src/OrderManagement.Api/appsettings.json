{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Data/order-management.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "OrderManagement.Api"
    }
  },
  "AllowedHosts": "*"
}